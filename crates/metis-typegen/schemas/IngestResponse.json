{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IngestResponse",
  "type": "object",
  "required": [
    "doc_id",
    "ingest",
    "n_pages",
    "n_spans"
  ],
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "ingest": true,
    "n_pages": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "n_spans": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  }
}