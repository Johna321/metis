{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConversationMeta",
  "type": "object",
  "required": [
    "created_at",
    "id",
    "message_count",
    "pinned",
    "title",
    "updated_at"
  ],
  "properties": {
    "created_at": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "message_count": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "pinned": {
      "type": "boolean"
    },
    "title": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}