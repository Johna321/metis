{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChatStreamEvent",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "kind",
        "text"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "TextDelta"
          ]
        },
        "text": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "ToolCallStart"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "text"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "ToolCallDelta"
          ]
        },
        "text": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "arguments",
        "id",
        "kind",
        "name"
      ],
      "properties": {
        "arguments": true,
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "ToolCallDone"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "role"
      ],
      "properties": {
        "content": {
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "MessageDone"
          ]
        },
        "role": {
          "type": "string"
        },
        "tool_calls": true
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "AgentDone"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "Error"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    }
  ]
}