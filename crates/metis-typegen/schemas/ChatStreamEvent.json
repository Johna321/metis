{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChatStreamEvent",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "kind",
        "text"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "TextDelta"
          ]
        },
        "text": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "ToolCallStart"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "text"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "ToolCallDelta"
          ]
        },
        "text": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "arguments",
        "id",
        "kind",
        "name"
      ],
      "properties": {
        "arguments": true,
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "ToolCallDone"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "role"
      ],
      "properties": {
        "content": {
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "MessageDone"
          ]
        },
        "role": {
          "type": "string"
        },
        "tool_calls": true
      }
    },
    {
      "type": "object",
      "required": [
        "items",
        "kind",
        "tool_call_id",
        "tool_name"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EvidenceItem"
          }
        },
        "kind": {
          "type": "string",
          "enum": [
            "CitationData"
          ]
        },
        "tool_call_id": {
          "type": "string"
        },
        "tool_name": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "AgentDone"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "kind",
        "message"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "Error"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    }
  ],
  "definitions": {
    "EvidenceItem": {
      "type": "object",
      "required": [
        "bbox_norm",
        "page",
        "score",
        "span_id",
        "text"
      ],
      "properties": {
        "bbox_norm": {
          "type": "array",
          "items": {
            "type": "number",
            "format": "double"
          },
          "maxItems": 4,
          "minItems": 4
        },
        "page": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "score": {
          "type": "number",
          "format": "double"
        },
        "span_id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      }
    }
  }
}