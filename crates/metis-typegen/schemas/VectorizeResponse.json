{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VectorizeResponse",
  "type": "object",
  "required": [
    "doc_id",
    "model",
    "n_embedded",
    "was_cached"
  ],
  "properties": {
    "dim": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0.0
    },
    "doc_id": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "n_embedded": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "n_skipped": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0.0
    },
    "was_cached": {
      "type": "boolean"
    }
  }
}