{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceItem",
  "type": "object",
  "required": [
    "bbox_norm",
    "page",
    "score",
    "span_id",
    "text"
  ],
  "properties": {
    "bbox_norm": {
      "type": "array",
      "items": {
        "type": "number",
        "format": "double"
      },
      "maxItems": 4,
      "minItems": 4
    },
    "page": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "score": {
      "type": "number",
      "format": "double"
    },
    "span_id": {
      "type": "string"
    },
    "text": {
      "type": "string"
    }
  }
}