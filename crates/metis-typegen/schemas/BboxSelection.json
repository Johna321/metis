{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BboxSelection",
  "type": "object",
  "required": [
    "bbox_norm",
    "page"
  ],
  "properties": {
    "bbox_norm": {
      "type": "array",
      "items": {
        "type": "number",
        "format": "double"
      },
      "maxItems": 4,
      "minItems": 4
    },
    "page": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  }
}